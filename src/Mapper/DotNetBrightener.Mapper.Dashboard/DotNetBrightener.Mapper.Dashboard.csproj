<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <IsPackable>true</IsPackable>
        <PackageId>DotNetBrightener.Mapper.Dashboard</PackageId>
        <Title>DotNetBrightener.Mapper.Dashboard</Title>
        <Description>Swagger-like dashboard for visualizing mapper source types and their generated projections in ASP.NET Core applications.</Description>
        <PackageTags>dashboard visualization swagger aspnetcore dto projection source-generator</PackageTags>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\DotNetBrightener.Mapper.Attributes\DotNetBrightener.Mapper.Attributes.csproj" />
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Include="Assets\**\*" />
        <EmbeddedResource Include="Templates\**\*.html" />
    </ItemGroup>

</Project>
